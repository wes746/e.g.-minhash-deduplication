import re
import multiprocessing as mp
from datasketch import MinHash, MinHashLSH
from typing import List, Dict, Set

# --- CONFIGURATION ---
NUM_PERMUTATIONS = 128  # Higher = more accurate but slower
JACCARD_THRESHOLD = 0.85  # Similarity threshold for considering a document a duplicate
N_CORES = mp.cpu_count() - 1

def preprocess_text(text: str) -> Set[str]:
    """
    Standardizes text and generates word-level n-grams (shingles).
    """
    text = text.lower()
    text = re.sub(r'[^\w\s]', '', text)
    tokens = text.split()
    # Create 3-grams for hashing
    shingles = set([' '.join(tokens[i:i+3]) for i in range(max(1, len(tokens) - 2))])
    return shingles

def create_minhash(doc_id: str, text: str) -> Dict:
    """
    Generates a MinHash signature for a single document.
    """
    shingles = preprocess_text(text)
    m = MinHash(num_perm=NUM_PERMUTATIONS)
    for shingle in shingles:
        m.update(shingle.encode('utf-8'))
    return {"id": doc_id, "minhash": m}

def run_deduplication_pipeline(dataset: List[Dict[str, str]]) -> List[Dict[str, str]]:
    """
    Processes a dataset to identify and remove near-duplicate documents.
    Expects a list of dictionaries: [{'id': 'doc1', 'text': '...'}, ...]
    """
    print(f"Starting pipeline on {len(dataset)} documents using {N_CORES} cores...")
    
    # Step 1: Parallel MinHash generation
    pool = mp.Pool(processes=N_CORES)
    minhash_results = pool.starmap(
        create_minhash, 
        [(doc['id'], doc['text']) for doc in dataset]
    )
    pool.close()
    pool.join()

    # Step 2: Build the LSH index for fast similarity search
    lsh = MinHashLSH(threshold=JACCARD_THRESHOLD, num_perm=NUM_PERMUTATIONS)
    
    unique_docs = []
    seen_ids = set()

    for item in minhash_results:
        doc_id = item["id"]
        m_hash = item["minhash"]
        
        # Query the LSH index for near-duplicates
        duplicates = lsh.query(m_hash)
        
        # If no duplicates exist in our seen set, add it
        if not any(dup_id in seen_ids for dup_id in duplicates):
            lsh.insert(doc_id, m_hash)
            seen_ids.add(doc_id)
            # Find original text to keep
            original_doc = next(doc for doc in dataset if doc['id'] == doc_id)
            unique_docs.append(original_doc)

    print(f"Deduplication complete. Retained {len(unique_docs)} unique documents.")
    return unique_docs

if __name__ == "__main__":
    # Example Usage for the Open Source Community
    sample_data = [
        {"id": "1", "text": "The quick brown fox jumps over the lazy dog."},
        {"id": "2", "text": "The quick brown fox jumped over the lazy dog."}, # Near duplicate
        {"id": "3", "text": "Artificial intelligence requires massive amounts of clean data."},
        {"id": "4", "text": "AI needs a lot of clean data to function properly."}
    ]
    
    clean_dataset = run_deduplication_pipeline(sample_data)
    for doc in clean_dataset:
        print(f"Kept: {doc['id']}")
